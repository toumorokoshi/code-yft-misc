{
  "name": "yft-misc",
  "displayName": "YFT Misc",
  "description": "Miscellaneous utilities for code editing",
  "publisher": "yft",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/toumorokoshi/code-yft-misc.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:yft-misc.downloadFile",
    "onCommand:yft-misc.uploadFile",
    "onCommand:yft-misc.installVsixFromOpenvsx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yft-misc.helloWorld",
        "title": "YFT Misc: Hello World"
      },
      {
        "command": "yft-misc.insertHotlink",
        "title": "YFT Misc: Insert Hotlink"
      },
      {
        "command": "yft-misc.openHotlink",
        "title": "YFT Misc: Open Hotlink"
      },
      {
        "command": "yft-misc.downloadFile",
        "title": "YFT Misc: Download File to Local"
      },
      {
        "command": "yft-misc.uploadFile",
        "title": "YFT Misc: Upload File to Remote"
      },
      {
        "command": "yft-misc.installVsixFromOpenvsx",
        "title": "YFT Misc: Install .vsix from openvsx"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.0.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}